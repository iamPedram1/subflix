{
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2022",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "skipLibCheck": true,
    "strict": true,
    "noImplicitAny": true,
    "strictBindCallApply": true,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    "types": ["node", "express", "multer", "vitest/globals"],
    "paths": {
      "app.module": ["src/app.module"],
      "app.bootstrap": ["src/app.bootstrap"],
      "src/*": ["src/*"],
      "common/*": ["src/common/*"],
      "features/*": ["src/features/*"],
      "test/*": ["test/*"]
    }
  }
}
