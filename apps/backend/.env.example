NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/subflix
MAX_UPLOAD_BYTES=2097152
MAX_BODY_BYTES=32768
RATE_LIMIT_DEFAULT_LIMIT=120
RATE_LIMIT_DEFAULT_WINDOW_MS=60000
RATE_LIMIT_CLEANUP_INTERVAL_MS=60000
CACHE_DEFAULT_TTL_MS=300000
CACHE_CLEANUP_INTERVAL_MS=60000
CACHE_MAX_ENTRIES=1000
TMDB_API_BASE_URL=https://api.themoviedb.org/3
TMDB_API_READ_TOKEN=
TMDB_MOVIE_SEARCH_CACHE_TTL_MS=2592000000
TMDB_SERIES_SEARCH_CACHE_TTL_MS=86400000
TMDB_MOVIE_DETAIL_CACHE_TTL_MS=2592000000
TMDB_SERIES_DETAIL_CACHE_TTL_MS=86400000
TMDB_INCLUDE_ADULT=false
TMDB_DEFAULT_LANGUAGE=en-US
SUBTITLE_SOURCE_CACHE_TTL_MS=21600000
SUBTITLE_DOWNLOAD_MAX_BYTES=5242880
SUBTITLE_ZIP_MAX_EXTRACTED_BYTES=10485760
SUBDL_API_BASE_URL=https://api.subdl.com/api/v1
SUBDL_API_KEY=
SUBDL_ENABLED=true
SUBDL_TIMEOUT_MS=7000
PODNAPISI_BASE_URL=https://www.podnapisi.net
PODNAPISI_ENABLED=true
PODNAPISI_TIMEOUT_MS=10000
TVSUBS_BASE_URL=https://www.tvsubtitles.net
TVSUBS_ENABLED=true
TVSUBS_TIMEOUT_MS=10000
SUBTITLE_ALIGNMENT_ENABLED=true
SUBTITLE_ALIGNMENT_MAX_OFFSET_MS=10000
SUBTITLE_ALIGNMENT_STEP_MS=1000
SUBTITLE_ALIGNMENT_CONFIDENCE_THRESHOLD=60
AUTH_JWT_SECRET=replace_with_secure_secret
AUTH_ACCESS_TOKEN_TTL_SECONDS=900
AUTH_REFRESH_TOKEN_TTL_DAYS=30
AUTH_EMAIL_VERIFICATION_TTL_HOURS=24
AUTH_PASSWORD_RESET_TTL_HOURS=2
AUTH_BCRYPT_SALT_ROUNDS=12
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_SERVICE_ACCOUNT_JSON=
TRANSLATION_JOB_STALE_AFTER_MS=300000
TRANSLATION_JOB_MAX_ATTEMPTS=3
TRANSLATION_JOB_RECOVERY_ENABLED=true
TRANSLATION_JOB_RECOVERY_INTERVAL_MS=60000
TRANSLATION_JOB_STARTUP_RECOVERY_ENABLED=true
TRANSLATION_JOB_MAX_CONCURRENCY=3
TRANSLATION_JOB_DISPATCH_ON_STARTUP_ENABLED=true
TRANSLATION_JOB_DISPATCH_POLL_INTERVAL_MS=10000
TRANSLATION_JOB_DISPATCH_FAIRNESS_THRESHOLD_MS=300000
