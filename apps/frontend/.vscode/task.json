{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Watch Providers",
      "type": "shell",
      "command": "dart run build_runner watch --delete-conflicting-outputs",
      "runOptions": {
        "runOn": "folderOpen"
      },
      "presentation": {
        "reveal": "silent",
        "panel": "shared"
      },
      "isBackground": true,
      "problemMatcher": ["$dart-build_runner"]
    }
  ]
}
